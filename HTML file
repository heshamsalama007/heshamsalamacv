<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hesham Salama – Personal Brand</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #0a1628;
    --gold: #c9a84c;
    --gold-light: #e8c96a;
    --cream: #f5f0e8;
    --text: #1a2640;
    --muted: #6b7a94;
    --line: rgba(201,168,76,0.25);
  }

  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); overflow-x: hidden; }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2.5rem;
    background: rgba(10,22,40,0.97);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .nav-logo { font-family: 'Playfair Display', serif; color: var(--gold); font-size: 1rem; letter-spacing: 0.04em; }
  .nav-links { display: flex; gap: 1.8rem; }
  .nav-links a { color: rgba(245,240,232,0.7); font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: var(--gold); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    background: var(--navy);
    display: flex; align-items: center;
    padding: 5rem 2.5rem 3.5rem;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: -15%; right: -5%;
    width: 480px; height: 480px;
    background: radial-gradient(circle, rgba(201,168,76,0.13) 0%, transparent 70%);
    border-radius: 50%; pointer-events: none;
  }
  .hero-wm {
    position: absolute; right: 4%; bottom: 4%;
    font-family: 'Playfair Display', serif;
    font-size: 13rem; font-weight: 900; color: rgba(201,168,76,0.04);
    line-height: 1; pointer-events: none; user-select: none;
  }

  .hero-layout {
    display: flex; align-items: center; gap: 5rem;
    max-width: 1060px; width: 100%; position: relative; z-index: 1;
  }

  /* ── PHOTO ── */
  .hero-photo-wrap {
    flex-shrink: 0;
    width: 280px; height: 340px;
    position: relative;
    animation: fadeUp 0.8s 0.1s ease both;
  }
  .hero-photo-wrap::before {
    content: '';
    position: absolute; top: 14px; left: 14px;
    width: 100%; height: 100%;
    border: 2px solid var(--gold);
    border-radius: 4px;
    opacity: 0.45;
    z-index: 0;
  }
  .hero-photo-wrap::after {
    content: '';
    position: absolute; bottom: -10px; left: -10px;
    width: 56px; height: 4px;
    background: var(--gold);
    border-radius: 2px;
    z-index: 2;
  }
  .hero-photo {
    width: 100%; height: 100%;
    object-fit: cover; object-position: top center;
    border-radius: 4px;
    display: block;
    position: relative; z-index: 1;
    filter: grayscale(8%) contrast(1.04);
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }

  /* ── HERO TEXT ── */
  .hero-text { flex: 1; min-width: 0; }
  .hero-tag {
    display: inline-block; margin-bottom: 1.1rem;
    font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold); border: 1px solid rgba(201,168,76,0.5);
    padding: 0.28rem 0.8rem; border-radius: 2px;
    animation: fadeUp 0.7s ease both;
  }
  .hero-text h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 4.5vw, 4.2rem);
    color: var(--cream); line-height: 1.05; font-weight: 900;
    animation: fadeUp 0.7s 0.1s ease both;
  }
  .hero-text h1 em { color: var(--gold); font-style: italic; }
  .hero-sub {
    margin-top: 1.1rem; font-size: 0.95rem; color: rgba(245,240,232,0.58);
    font-weight: 300; line-height: 1.75;
    animation: fadeUp 0.7s 0.2s ease both;
  }
  .hero-pills {
    display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 1.5rem;
    animation: fadeUp 0.7s 0.3s ease both;
  }
  .pill {
    background: rgba(201,168,76,0.1); color: var(--gold);
    border: 1px solid rgba(201,168,76,0.28);
    padding: 0.32rem 0.85rem; border-radius: 100px; font-size: 0.74rem; font-weight: 500;
  }
  .hero-cta {
    display: flex; gap: 0.9rem; margin-top: 2rem;
    animation: fadeUp 0.7s 0.4s ease both;
  }
  .btn-primary {
    background: var(--gold); color: var(--navy);
    padding: 0.72rem 1.7rem; border-radius: 3px; font-weight: 600;
    font-size: 0.8rem; letter-spacing: 0.06em; text-transform: uppercase;
    border: none; cursor: pointer; transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
  .btn-outline {
    background: transparent; color: var(--cream);
    padding: 0.72rem 1.7rem; border-radius: 3px; font-weight: 500;
    font-size: 0.8rem; letter-spacing: 0.06em;
    border: 1px solid rgba(245,240,232,0.22); cursor: pointer;
    transition: border-color 0.2s, color 0.2s, transform 0.15s;
  }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }

  /* ── STATS BAR ── */
  .stats-bar { background: var(--gold); display: flex; justify-content: center; flex-wrap: wrap; }
  .stat { padding: 1.3rem 2.3rem; text-align: center; flex: 1 1 120px; border-right: 1px solid rgba(10,22,40,0.15); }
  .stat:last-child { border-right: none; }
  .stat-num { font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 900; color: var(--navy); }
  .stat-label { font-size: 0.67rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(10,22,40,0.6); margin-top: 0.15rem; }

  /* ── GENERIC SECTION ── */
  section { padding: 4.5rem 2.5rem; max-width: 1060px; margin: 0 auto; }
  .section-label { font-size: 0.67rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem; }
  .section-title { font-family: 'Playfair Display', serif; font-size: clamp(1.65rem, 3vw, 2.3rem); font-weight: 700; color: var(--navy); line-height: 1.2; margin-bottom: 2.4rem; }
  .section-title span { color: var(--gold); font-style: italic; }

  /* ── TIMELINE ── */
  .timeline { position: relative; }
  .timeline::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 1px; background: var(--line); }
  .t-item { padding-left: 2.2rem; margin-bottom: 2.6rem; position: relative; cursor: pointer; }
  .t-item::before { content: ''; position: absolute; left: -5px; top: 0.4rem; width: 11px; height: 11px; border-radius: 50%; background: var(--cream); border: 2px solid var(--gold); transition: background 0.2s; }
  .t-item:hover::before { background: var(--gold); }
  .t-period { font-size: 0.69rem; letter-spacing: 0.1em; color: var(--gold); text-transform: uppercase; margin-bottom: 0.25rem; }
  .t-title { font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 700; color: var(--navy); }
  .t-org { font-size: 0.83rem; color: var(--muted); margin: 0.2rem 0; }
  .t-body { font-size: 0.85rem; line-height: 1.75; color: var(--text); margin-top: 0.6rem; max-height: 0; overflow: hidden; transition: max-height 0.4s ease; }
  .t-item.open .t-body { max-height: 500px; }
  .t-toggle { font-size: 0.72rem; color: var(--gold); margin-top: 0.35rem; font-weight: 500; }

  /* ── EDUCATION ── */
  .edu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1.1rem; }
  .edu-card { background: var(--navy); border-radius: 6px; padding: 1.6rem; border: 1px solid rgba(201,168,76,0.14); transition: transform 0.25s, border-color 0.25s; position: relative; overflow: hidden; }
  .edu-card::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.3s; }
  .edu-card:hover { transform: translateY(-4px); border-color: rgba(201,168,76,0.38); }
  .edu-card:hover::after { transform: scaleX(1); }
  .edu-badge { display: inline-block; font-size: 0.62rem; letter-spacing: 0.13em; text-transform: uppercase; color: var(--gold); background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.22); padding: 0.2rem 0.55rem; border-radius: 2px; margin-bottom: 0.85rem; }
  .edu-degree { font-family: 'Playfair Display', serif; color: var(--cream); font-size: 0.98rem; font-weight: 700; line-height: 1.35; margin-bottom: 0.4rem; }
  .edu-inst { font-size: 0.78rem; color: rgba(245,240,232,0.52); }
  .edu-year { font-size: 0.72rem; color: var(--gold); margin-top: 0.65rem; }

  /* ── CERTIFICATIONS ── */
  .cert-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(205px, 1fr)); gap: 0.85rem; }
  .cert-item { display: flex; align-items: flex-start; gap: 0.8rem; padding: 1.05rem; border: 1px solid rgba(201,168,76,0.14); border-radius: 5px; background: white; transition: box-shadow 0.2s, border-color 0.2s; }
  .cert-item:hover { box-shadow: 0 4px 18px rgba(201,168,76,0.11); border-color: rgba(201,168,76,0.38); }
  .cert-icon { width: 29px; height: 29px; background: rgba(201,168,76,0.1); border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.88rem; }
  .cert-name { font-size: 0.79rem; font-weight: 500; color: var(--navy); line-height: 1.4; }
  .cert-body { font-size: 0.69rem; color: var(--muted); margin-top: 0.18rem; }

  /* ── SKILLS ── */
  .skills-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  .skill-group-label { font-size: 0.67rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.95rem; }
  .skill-bar-wrap { margin-bottom: 1rem; }
  .skill-bar-label { display: flex; justify-content: space-between; font-size: 0.79rem; margin-bottom: 0.32rem; }
  .skill-bar-track { height: 4px; background: rgba(201,168,76,0.14); border-radius: 2px; overflow: hidden; }
  .skill-bar-fill { height: 100%; background: linear-gradient(90deg, var(--gold), var(--gold-light)); border-radius: 2px; width: 0; transition: width 1s ease; }
  .tag-cloud { display: flex; flex-wrap: wrap; gap: 0.48rem; }
  .tag { padding: 0.38rem 0.85rem; border-radius: 100px; font-size: 0.74rem; border: 1px solid rgba(10,22,40,0.13); background: white; color: var(--navy); font-weight: 500; transition: background 0.2s, color 0.2s; cursor: default; }
  .tag:hover { background: var(--navy); color: var(--gold); border-color: var(--navy); }

  /* ── PUBLICATIONS ── */
  .pub-list { list-style: none; }
  .pub-item { padding: 1.2rem 0; border-bottom: 1px solid rgba(201,168,76,0.14); display: flex; gap: 1rem; align-items: flex-start; }
  .pub-num { font-family: 'Playfair Display', serif; font-size: 1.45rem; color: rgba(201,168,76,0.22); font-weight: 900; line-height: 1; flex-shrink: 0; }
  .pub-title { font-weight: 600; font-size: 0.87rem; color: var(--navy); line-height: 1.5; }
  .pub-meta { font-size: 0.75rem; color: var(--muted); margin-top: 0.22rem; }

  /* ── CONTACT ── */
  .contact-section { background: var(--navy); padding: 5rem 2.5rem; text-align: center; }
  .contact-section .section-title { color: var(--cream); }
  .contact-grid { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; margin-top: 2rem; }
  .contact-item { display: flex; flex-direction: column; align-items: center; gap: 0.45rem; }
  .contact-icon { width: 44px; height: 44px; border: 1px solid rgba(201,168,76,0.28); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; color: var(--gold); }
  .contact-val { font-size: 0.84rem; color: rgba(245,240,232,0.68); }
  .contact-val a { color: inherit; text-decoration: none; }
  .contact-val a:hover { color: var(--gold); }

  footer { background: #060e1c; text-align: center; padding: 1.2rem; font-size: 0.72rem; color: rgba(245,240,232,0.28); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
  .reveal { opacity: 0; transform: translateY(26px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  .alt-bg { background: #f0ebe0; }
  .alt-bg > .inner { max-width: 1060px; margin: 0 auto; padding: 4.5rem 2.5rem; }

  @media (max-width: 820px) {
    .hero-layout { flex-direction: column; gap: 2.5rem; align-items: flex-start; }
    .hero-photo-wrap { width: 200px; height: 240px; }
  }
  @media (max-width: 700px) {
    nav { padding: 1rem 1.2rem; }
    .nav-links { gap: 1rem; }
    .hero { padding: 5.5rem 1.5rem 3rem; }
    section { padding: 3.5rem 1.5rem; }
    .alt-bg > .inner { padding: 3.5rem 1.5rem; }
    .skills-layout { grid-template-columns: 1fr; gap: 2rem; }
    .stat { padding: 1.1rem 1.2rem; }
  }
</style>
</head>
